// NextGen Growth Agent — Prisma schema
// Run: npx prisma db push  (or)  npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ────────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  businessProfile     BusinessProfile?
  socialAccounts      SocialAccount[]
  posts               Post[]
  images              Image[]
  blogs               Blog[]
  seoSuggestions      SeoSuggestion[]
  schedules           Schedule[]
  syndicationTargets  SyndicationTarget[]
  competitors         Competitor[]
  postingSchedule     PostingSchedule?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Business profile ────────────────────────────────────────────────────────
model BusinessProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  websiteUrl      String
  businessName    String
  services        String   @db.Text
  targetAudience  String   @db.Text
  brandTone       String
  keywords        String[] @default([])
  logoUrl         String?
  logoPosition    String   @default("bottom-right") // top-left, top-right, bottom-left, bottom-right
  defaultPostTime String   @default("09:00")        // HH:mm in user-local time
  autoPublish     Boolean  @default(false)
  websiteSummary  String?  @db.Text                  // AI-extracted summary of the site
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

// ── Connected social accounts (Meta OAuth tokens) ───────────────────────────
model SocialAccount {
  id              String    @id @default(cuid())
  userId          String
  platform        String    // "facebook" | "instagram"
  externalId      String    // FB Page ID or IG Business Account ID
  name            String
  pictureUrl      String?
  accessToken     String    @db.Text
  tokenExpiresAt  DateTime?
  scopes          String[]  @default([])
  connectedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts         Post[]
  publications  PostPublication[]

  @@unique([userId, platform, externalId])
  @@map("social_accounts")
}

// ── Manual syndication targets (subreddits, FB groups user owns, etc.) ──────
// One row = one place the user wants to push content to. The platform field
// indicates which connected SocialAccount drives the publishing.
model SyndicationTarget {
  id          String   @id @default(cuid())
  userId      String
  platform    String   // "reddit", "medium-pub", "fb-group", etc.
  /// Identifier within the platform (subreddit name, publication slug, group id, …)
  targetRef   String
  /// Human label for the UI
  label       String
  /// Free-form notes / per-target rules (e.g. "self-promo allowed Sundays only")
  notes       String?  @db.Text
  enabled     Boolean  @default(true)
  /// Last time we successfully posted here (used for cooldown logic)
  lastPostedAt DateTime?
  /// Minimum hours to wait between posts to this target (default 168h = 1 week)
  cooldownHrs Int      @default(168)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, targetRef])
  @@index([userId, platform, enabled])
  @@map("syndication_targets")
}

// ── Per-platform publish records ────────────────────────────────────────────
// One Post can be published to many platforms. Each attempt gets one row so
// we can show per-platform status, retry the failed ones, and link out to the
// live URL on each platform.
model PostPublication {
  id              String     @id @default(cuid())
  postId          String
  socialAccountId String
  /// Optional reference to a SyndicationTarget row (subreddit, etc.)
  targetId        String?
  status          PostStatus @default(SCHEDULED)
  externalPostId  String?
  externalUrl     String?
  failureReason   String?    @db.Text
  publishedAt     DateTime?
  scheduledFor    DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount  SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([socialAccountId, status])
  @@map("post_publications")
}

// ── Generated posts ─────────────────────────────────────────────────────────
enum PostStatus {
  DRAFT
  AWAITING_APPROVAL
  SCHEDULED
  PUBLISHED
  FAILED
}

model Post {
  id              String      @id @default(cuid())
  userId          String
  socialAccountId String?
  platform        String?     // "facebook" | "instagram" — null until target chosen
  title           String?     // optional explicit title for the post
  hook            String      @db.Text
  body            String      @db.Text
  cta             String      @db.Text
  hashtags        String[]    @default([])
  websiteLink     String?
  videoUrl        String?     @db.Text   // optional video URL/upload
  fullCaption     String      @db.Text   // pre-assembled FB/IG caption
  status          PostStatus  @default(DRAFT)
  scheduledFor    DateTime?
  publishedAt     DateTime?
  externalPostId  String?     // FB/IG post id once published
  externalUrl     String?     // permalink to the live post (for analytics linkout)
  failureReason   String?     @db.Text
  topic           String?
  modelUsed       String?
  /// Cached impression count from Graph API insights (auto-refreshed)
  impressions     Int         @default(0)
  /// Cached reach/engagement counts
  reach           Int         @default(0)
  engagements     Int         @default(0)
  insightsAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount?    @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  image         Image?
  schedule      Schedule?
  publications  PostPublication[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("posts")
}

// ── Generated images (linked 1:1 to a post in MVP) ──────────────────────────
model Image {
  id              String   @id @default(cuid())
  userId          String
  postId          String?  @unique
  prompt          String   @db.Text
  provider        String   // "pollinations" | "openai" | "replicate" | "upload"
  /// "generated" (AI) or "uploaded" (user-uploaded photo)
  source          String   @default("generated")
  /// Aspect ratio used at upload/crop time (e.g. "1:1", "1.91:1", "4:5", "9:16")
  aspectRatio     String?
  rawUrl          String   @db.Text  // pre-overlay (provider URL or Cloudinary)
  finalUrl        String   @db.Text  // post-overlay (Cloudinary)
  width           Int?
  height          Int?
  logoApplied     Boolean  @default(false)
  createdAt       DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@map("images")
}

// ── Blog drafts ─────────────────────────────────────────────────────────────
model Blog {
  id                  String   @id @default(cuid())
  userId              String
  seoTitle            String
  metaTitle           String?              // SEO title tag (different from H1)
  metaDescription     String   @db.Text
  slug                String
  contentMarkdown     String   @db.Text
  contentHtml         String?  @db.Text    // optional pre-rendered HTML
  headings            String[] @default([])   // H2/H3 outline
  keywords            String[] @default([])
  /// Keyword clusters: [{label,keywords:[]}] stored as JSON
  keywordClusters     Json?
  /// Semantic / LSI keywords
  semanticKeywords    String[] @default([])
  /// FAQ block: [{q,a}]
  faqs                Json?
  internalLinks       String[] @default([])   // suggested internal links
  /// Recommended outbound/external links
  externalLinks       String[] @default([])
  /// Readability score (0-100, higher = easier)
  readabilityScore    Int?
  /// Composite SEO score (0-100)
  seoScore            Int?
  /// AI-suggested improvements
  improvementSuggestions String[] @default([])
  /// Public view count
  viewCount           Int      @default(0)
  cta                 String   @db.Text
  /// Inputs the user supplied so the page can re-render the brief
  targetAudience      String?  @db.Text
  tone                String?
  websiteUrl          String?
  status              String   @default("DRAFT") // DRAFT | PUBLISHED
  modelUsed           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  views BlogView[]

  @@unique([userId, slug])
  @@index([userId, createdAt])
  @@map("blogs")
}

// ── Public blog view tracking (anon) ────────────────────────────────────────
model BlogView {
  id        String   @id @default(cuid())
  blogId    String
  ipHash    String?  // hashed IP for unique-per-day dedup
  userAgent String?  @db.Text
  referrer  String?  @db.Text
  country   String?
  createdAt DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId, createdAt])
  @@map("blog_views")
}

// ── SEO suggestions (daily generated tips) ──────────────────────────────────
model SeoSuggestion {
  id                String   @id @default(cuid())
  userId            String
  forDate           DateTime @default(now()) @db.Date
  blogTitles        String[] @default([])
  metaTitles        String[] @default([])
  metaDescriptions  String[] @default([])
  keywords          String[] @default([])
  faqs              Json?     // [{ q, a }]
  outreachMessages  String[] @default([])
  directories       String[] @default([])  // suggested submission targets
  notes             String?  @db.Text
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, forDate])
  @@map("seo_suggestions")
}

// ── Scheduling jobs (one per scheduled post) ────────────────────────────────
enum ScheduleStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  CANCELLED
}

model Schedule {
  id           String         @id @default(cuid())
  userId       String
  postId       String         @unique
  runAt        DateTime
  status       ScheduleStatus @default(PENDING)
  attempts     Int            @default(0)
  lastError    String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([status, runAt])
  @@map("schedules")
}

// ── Competitor tracking ────────────────────────────────────────────────────
model Competitor {
  id          String   @id @default(cuid())
  userId      String
  name        String
  websiteUrl  String?
  linkedinUrl String?
  twitterUrl  String?
  instagramUrl String?
  facebookUrl String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights CompetitorInsight[]

  @@index([userId, createdAt])
  @@map("competitors")
}

model CompetitorInsight {
  id                  String   @id @default(cuid())
  competitorId        String
  /// Common topics they post about
  commonTopics        String[] @default([])
  /// e.g. "3-4 posts/week"
  postingFrequency    String?
  /// Topics they don't cover (opportunities)
  contentGaps         String[] @default([])
  /// Concrete content ideas user can pursue
  contentIdeas        String[] @default([])
  /// Recommended post topics for the user
  recommendedTopics   String[] @default([])
  /// Free-form summary
  summary             String?  @db.Text
  modelUsed           String?
  generatedAt         DateTime @default(now())

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId, generatedAt])
  @@map("competitor_insights")
}

// ── Per-platform variants of a generated post ──────────────────────────────
model PlatformPostVersion {
  id          String   @id @default(cuid())
  postId      String
  platform    String   // "facebook" | "instagram" | "linkedin" | "twitter"
  caption     String   @db.Text
  hashtags    String[] @default([])
  charCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([postId, platform])
  @@index([postId])
  @@map("platform_post_versions")
}

// ── User-level posting schedule (time range + frequency) ───────────────────
model PostingSchedule {
  id           String   @id @default(cuid())
  userId       String   @unique
  enabled      Boolean  @default(false)
  /// HH:mm — earliest local time a post may run
  startTime    String   @default("09:00")
  /// HH:mm — latest local time a post may run
  endTime      String   @default("18:00")
  /// Posts per day (1..5)
  postsPerDay  Int      @default(1)
  /// IANA timezone (e.g. "America/New_York"). Defaults to UTC.
  timezone     String   @default("UTC")
  /// Days of week (0=Sun .. 6=Sat). Empty = every day.
  daysOfWeek   Int[]    @default([])
  /// Auto-publish to all connected accounts when generated
  autoPublishAll Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("posting_schedules")
}
