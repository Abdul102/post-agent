# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, Railway, local Docker, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/nextgen_growth?schema=public"

# ── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# ── OpenAI (text generation: posts, blogs, SEO) ─────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ── Image generation provider ───────────────────────────────────────────────
# Options: "pollinations" (FREE, no key), "openai", "replicate"
IMAGE_PROVIDER="pollinations"
# Only required if IMAGE_PROVIDER="replicate"
REPLICATE_API_TOKEN=""

# ── Cloudinary (storage + transformations) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Meta Graph API (Facebook + Instagram + Threads) ─────────────────────────
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="http://localhost:3000/api/social-accounts/meta/callback"

# ── Reddit (https://www.reddit.com/prefs/apps — type: "web app") ────────────
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_REDIRECT_URI="http://localhost:3000/api/social-accounts/reddit/callback"

# ── Cron protection ─────────────────────────────────────────────────────────
CRON_SECRET="replace-with-a-long-random-string"
